      "parameters": {
        "jsCode": "// Filter no-shows that haven't received reschedule email yet\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const data = item.json;\n  \n  // Skip if reschedule email already sent\n  if (data.reschedule_email_sent) {\n    continue;\n  }\n  \n  // Skip if no email address\n  if (!data.patient_email) {\n    continue;\n  }\n  \n  results.push({ json: data });\n}\n\nif (results.length === 0) {\n  return [{ json: { no_noshows: true } }];\n}\n\nreturn results;"
      },
