    {
      "parameters": {
        "jsCode": "// Find patients with last visit > 6 months ago\nconst items = $input.all();\nconst now = DateTime.now().setZone('Europe/Bucharest');\nconst sixMonthsAgo = now.minus({ months: 6 });\n\n// Group appointments by patient email to find last visit\nconst patientLastVisit = {};\n\nfor (const item of items) {\n  const data = item.json;\n  const email = data.patient_email;\n  const aptDate = data.appointment_datetime;\n  const status = data.status;\n  \n  if (!email || !aptDate) continue;\n  if (status !== 'completed') continue;\n  \n  const visitDate = DateTime.fromISO(aptDate);\n  \n  if (!patientLastVisit[email] || visitDate > patientLastVisit[email].lastVisit) {\n    patientLastVisit[email] = {\n      email: email,\n      name: data.patient_name || 'Pacient',\n      phone: data.patient_phone || '',\n      lastVisit: visitDate,\n      lastProcedure: data.procedure || 'Consultatie'\n    };\n  }\n}\n\n// Filter patients who haven't visited in 6+ months\nconst inactivePatients = [];\n\nfor (const email in patientLastVisit) {\n  const patient = patientLastVisit[email];\n  \n  if (patient.lastVisit < sixMonthsAgo) {\n    inactivePatients.push({\n      json: {\n        patient_email: patient.email,\n        patient_name: patient.name,\n        patient_phone: patient.phone,\n        last_visit: patient.lastVisit.toFormat('dd MMMM yyyy'),\n        last_procedure: patient.lastProcedure,\n        months_since_visit: Math.floor(now.diff(patient.lastVisit, 'months').months)\n      }\n    });\n  }\n}\n\nif (inactivePatients.length === 0) {\n  return [{ json: { no_inactive: true } }];\n}\n\ninactivePatients.sort((a, b) => b.json.months_since_visit - a.json.months_since_visit);\nreturn inactivePatients.slice(0, 10);"
      },
