        920,
        400
      ],
      "parameters": {
        "promptType": "define",
        "text": "=Analizează următorul lead pentru o clinică dentară și determină calitatea și urgența.\n\nDATELE LEAD-ULUI:\n- Nume: {{ $json.name }}\n- Telefon: {{ $json.phone }}\n- Email: {{ $json.email }}\n- Sursă: {{ $json.source }}\n- Procedură de interes: {{ $json.procedure_interest }}\n- Mesaj/Note: {{ $json.notes }}\n- Ore preferate: {{ $json.preferred_slots }}\n- Limbă: {{ $json.language }}\n\nRETURNEAZĂ UN OBIECT JSON cu următoarele câmpuri (DOAR JSON, fără explicații):\n{\n  \"quality_score\": <număr 1-10>,\n  \"urgency\": \"<high|medium|low>\",\n  \"lead_type\": \"<hot|warm|cold>\",\n  \"recommended_action\": \"<acțiunea recomandată în română>\",\n  \"key_insights\": \"<observații cheie în română, max 2 propoziții>\"\n}\n\nCRITERII DE EVALUARE:\n- Score 8-10 (HOT): Procedură specifică menționată, date complete, mesaj detaliat\n- Score 5-7 (WARM): Date parțiale, interes general\n- Score 1-4 (COLD): Date minime, fără procedură specifică\n\nURGENȚA:\n- HIGH: Menționează durere, urgență, tratament început\n- MEDIUM: Procedură electivă (albire, implant)\n- LOW: Consultație generală, control"
      }
    },
    {
      "id": "parse-qualification",
      "name": "Parse AI Qualification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        400
      ],
      "parameters": {
        "jsCode": "// Parse AI qualification and merge with lead data\nconst leadData = $('Normalize Lead').first().json;\nconst aiOutput = $json.output || '{}';\n\nlet qualification = {};\ntry {\n  // Extract JSON from AI response\n  const jsonMatch = aiOutput.match(/\\{[\\s\\S]*\\}/);\n  if (jsonMatch) {\n    qualification = JSON.parse(jsonMatch[0]);\n  }\n} catch (e) {\n  qualification = {\n    quality_score: 5,\n    urgency: 'medium',\n    lead_type: 'warm',\n    recommended_action: 'Contactare standard',\n    key_insights: 'Nu s-a putut analiza automat'\n  };\n}\n\nreturn [{\n  json: {\n    ...leadData,\n    ai_quality_score: qualification.quality_score || 5,\n    ai_urgency: qualification.urgency || 'medium',\n    ai_lead_type: qualification.lead_type || 'warm',\n    ai_recommended_action: qualification.recommended_action || '',\n    ai_insights: qualification.key_insights || ''\n  }\n}];"
      }
    },
