pai.app.n8n.cloud/form/dental-schedule?lead_id={{ $json.lead_id }}&name={{ encodeURIComponent($json.name || '') }}&email={{ encodeURIComponent($json.email || '') }}&phone={{ $json.phone || '' }}&source={{ $json.source || '' }}&language=ro\" class=\"cta-button\">Programeaza Vizita</a>\n        </div>\n        <div class=\"info-box\">\n          <p><strong>Ce va asteapta:</strong></p>\n          <ul style=\"margin: 8px 0; padding-left: 20px;\">\n            <li>Alegeti din intervalele orare disponibile</li>\n            <li>Confirmare instantanee prin email</li>\n            <li>Reminder automat inainte de vizita</li>\n          </ul>\n        </div>\n        <p>Aveti intrebari urgente? Nu ezitati sa ne contactati direct la telefon pentru asistenta imediata.</p>\n        <p style=\"margin-top: 25px;\">Cu stima,<br><strong>Echipa Dental Studio</strong></p>\n      </div>\n    </div>\n    <div class=\"footer\">\n      <p><strong>Dental Studio</strong></p>\n      <p>Programari: Luni - Vineri, 09:00 - 18:00</p>\n    </div>\n  </div>\n</body>\n</html>",
