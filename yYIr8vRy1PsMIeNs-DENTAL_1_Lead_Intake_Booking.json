    {
      "parameters": {
        "jsCode": "// Check for duplicates within last 7 days\nconst currentLead = $('Normalize Lead').first().json;\nconst existingLeads = $input.all().map(i => i.json);\n\nconst sevenDaysAgo = new Date();\nsevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);\n\n// Find matching lead by phone or email within 7 days\nlet duplicateLead = null;\nfor (const lead of existingLeads) {\n  if (!lead.created_at || lead.created_at.trim() === '' || lead.created_at === ' ') continue;\n  \n  const leadDate = new Date(lead.created_at);\n  if (isNaN(leadDate.getTime()) || leadDate < sevenDaysAgo) continue;\n  \n  // Safely convert phone to string and clean\n  const currentPhone = String(currentLead.phone || '').replace(/\\D/g, '');\n  const leadPhone = String(lead.phone || '').replace(/\\D/g, '');\n  \n  const phoneMatch = currentPhone && leadPhone && currentPhone === leadPhone;\n  \n  // Safely compare emails\n  const currentEmail = String(currentLead.email || '').toLowerCase().trim();\n  const leadEmail = String(lead.email || '').toLowerCase().trim();\n  \n  const emailMatch = currentEmail && leadEmail && currentEmail === leadEmail;\n  \n  if (phoneMatch || emailMatch) {\n    duplicateLead = lead;\n    break;\n  }\n}\n\nreturn [{\n  json: {\n    ...currentLead,\n    is_duplicate: !!duplicateLead,\n    existing_lead_id: duplicateLead?.lead_id || null,\n    existing_row_number: duplicateLead?.row_number || null\n  }\n}];"
      },
