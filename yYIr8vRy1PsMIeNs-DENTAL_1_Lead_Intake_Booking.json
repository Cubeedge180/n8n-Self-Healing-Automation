        "html": "=<!DOCTYPE html>\n<html>\n<head><meta charset=\"UTF-8\">\n  <style>\n    body { font-family: 'Segoe UI', Arial, sans-serif; line-height: 1.7; color: #333; margin: 0; padding: 0; background-color: #f5f5f5; }\n    .container { max-width: 600px; margin: 0 auto; background: #ffffff; }\n    .header { background: linear-gradient(135deg, #2c5aa0 0%, #1e3a5f 100%); color: white; padding: 35px 30px; text-align: center; }\n    .header h1 { margin: 0; font-size: 26px; font-weight: 300; }\n    .header .subtitle { margin-top: 8px; opacity: 0.9; font-size: 14px; }\n    .content { padding: 35px 30px; }\n    .greeting { font-size: 18px; color: #2c5aa0; margin-bottom: 20px; }\n    .message { color: #555; font-size: 15px; }\n    .cta-container { text-align: center; margin: 30px 0; }\n    .cta-button { display: inline-block; background: #ff6d5a; color: white !important; padding: 16px 40px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 18px; }\n    .info-box { background: #f8f9fa; border-left: 4px solid #2c5aa0; padding: 20px; margin: 25px 0; border-radius: 0 8px 8px 0; }\n    .footer { background: #f8f9fa; padding: 25px 30px; text-align: center; border-top: 1px solid #e0e0e0; }\n    .footer p { margin: 5px 0; color: #666; font-size: 13px; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h1>Dental Studio</h1>\n      <div class=\"subtitle\">Your smile, our priority</div>\n    </div>\n    <div class=\"content\">\n      <div class=\"greeting\">Hello, {{ $json.name || 'dear patient' }}!</div>\n      <div class=\"message\">\n        <p>Thank you for your interest in our clinic. We received your request and we're ready to welcome you!</p>\n        <p><strong>Book your appointment now</strong> by clicking the button below. Choose your preferred date and time, and we'll confirm your spot instantly.</p>\n        <div class=\"cta-container\">\n          <a href=\"https://zappai.app.n8n.cloud/form/dental-schedule?lead_id={{ $json.lead_id }}&name={{ encodeURIComponent($json.name || '') }}&email={{ encodeURIComponent($json.email || '') }}&phone={{ $json.phone || '' }}&source={{ $json.source || '' }}&language=en\" class=\"cta-button\">Schedule Your Appointment</a>\n        </div>\n        <div class=\"info-box\">\n          <p><strong>What to expect:</strong></p>\n          <ul style=\"margin: 8px 0; padding-left: 20px;\">\n            <li>Choose from available time slots</li>\n            <li>Instant confirmation by email</li>\n            <li>Automatic reminder before your visit</li>\n          </ul>\n        </div>\n        <p>Have urgent questions? Don't hesitate to call us directly for immediate assistance.</p>\n        <p style=\"margin-top: 25px;\">Best regards,<br><strong>Dental Studio Team</strong></p>\n      </div>\n    </div>\n    <div class=\"footer\">\n      <p><strong>Dental Studio</strong></p>\n      <p>Appointments: Monday - Friday, 09:00 - 18:00</p>\n    </div>\n  </div>\n</body>\n</html>",
