      "parameters": {
        "jsCode": "// Normalize lead data from any source\nconst data = $input.first().json;\n\n// Generate unique lead ID\nconst leadId = 'LEAD-' + Date.now().toString(36).toUpperCase();\n\n// Extract and normalize fields\nconst normalized = {\n  lead_id: leadId,\n  source: data.source || 'unknown',\n  created_at: new Date().toISOString(),\n  \n  // Contact info - handle various field names from different sources\n  name: data.body?.name || data.name || data.caller_name || data.full_name || '',\n  phone: String(data.body?.phone || data.phone || data.caller_number || data.phone_number || '').replace(/[^0-9+]/g, ''),\n  email: (data.body?.email || data.email || '').toLowerCase().trim(),\n  \n  // Preferences\n  language: data.body?.language || data.language || 'ro',\n  procedure_interest: data.body?.procedure || data.procedure_interest || data.service || 'Consultatie generala',\n  notes: data.body?.message || data.message || data.notes || '',\n  preferred_slots: data.body?.preferred_time || data.preferred_slots || '',\n  \n  // Status tracking\n  status: 'new',\n  is_duplicate: false,\n  \n  // Original payload for debugging\n  original_payload: JSON.stringify(data).substring(0, 500)\n};\n\nreturn [{ json: normalized }];"
      },
      "id": "normalize-lead",
      "name": "Normalize Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        864,
        400
      ]
    },
