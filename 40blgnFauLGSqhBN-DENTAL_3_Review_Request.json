    {
      "id": "ai-personalize-review",
      "name": "AI Personalize Review Request",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.6,
      "position": [
        1264,
        304
      ],
      "parameters": {
        "promptType": "define",
        "text": "You are an email writer for a dental practice. Create a personalized review request email.\n\nPatient Details:\n- Name: {{ $json.patient_name }}\n- Email: {{ $json.email }}\n- Language: {{ $json.language }}\n- Treatment: {{ $json.treatment_type }}\n- Visit Date: {{ $json.visit_date }}\n\nWrite a warm, personalized email in the patient's preferred language ({{ $json.language }}) asking them to leave a Google review. Mention their specific treatment to make it personal.\n\nReturn ONLY a JSON object with:\n{\n  \"subject\": \"email subject line\",\n  \"body\": \"full email body in HTML format\"\n}"
      }
    },
    {
      "id": "parse-ai-email",
      "name": "Parse AI Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1464,
        304
      ],
      "parameters": {
        "jsCode": "const input = $input.first().json;\nlet aiResponse = input.output || input.text || '';\n\nlet emailData = { subject: 'Please Leave Us a Review', body: '' };\ntry {\n  const jsonMatch = aiResponse.match(/\\{[\\s\\S]*\\}/);\n  if (jsonMatch) {\n    emailData = JSON.parse(jsonMatch[0]);\n  }\n} catch (e) {\n  emailData.body = aiResponse;\n}\n\nreturn [{\n  json: {\n    ...input,\n    ai_subject: emailData.subject,\n    ai_body: emailData.body\n  }\n}];"
      }
    },
    {
      "id": "send-ai-review-email",
