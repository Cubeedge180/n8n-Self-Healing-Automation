    {
      "parameters": {
        "jsCode": "// Calculate 1 hour after appointment ends\n// Appointment duration defaults to 60 minutes if not specified\nconst input = $input.first().json;\nconst body = input.body || input;\n\nconst appointmentTime = body.appointment_time || body.appointment_datetime;\nconst durationMinutes = body.duration_minutes || 60;\n\nif (!appointmentTime) {\n  // If no appointment time, wait 1 hour from now\n  return [{\n    json: {\n      ...body,\n      wait_minutes: 60,\n      post_visit_reason: 'No appointment time provided, defaulting to 1h from now'\n    }\n  }];\n}\n\nconst aptTime = DateTime.fromISO(appointmentTime).setZone('Europe/Bucharest');\nconst appointmentEnd = aptTime.plus({ minutes: durationMinutes });\nconst postVisitTime = appointmentEnd.plus({ hours: 1 });\nconst now = DateTime.now().setZone('Europe/Bucharest');\n\n// Calculate minutes until post-visit email should be sent\nlet waitMinutes = postVisitTime.diff(now, 'minutes').minutes;\n\n// If the calculated time is in the past, don't wait\nif (waitMinutes < 0) {\n  waitMinutes = 1; // Send almost immediately\n}\n\nreturn [{\n  json: {\n    ...body,\n    appointment_end: appointmentEnd.toISO(),\n    post_visit_time: postVisitTime.toISO(),\n    wait_minutes: Math.round(waitMinutes),\n    wait_hours: Math.round(waitMinutes / 60 * 10) / 10\n  }\n}];"
      },
      "id": "calc-delay",
      "name": "Calculate 1h Post-Visit Delay",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        464,
        304
      ]
    },
