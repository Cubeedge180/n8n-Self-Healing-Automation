    {
      "parameters": {
        "jsCode": "// Check if the requested slot is available (procedure-duration aware)\nconst booking = $('Process Booking Request').first().json;\nconst existingAppointments = $input.all().map(i => i.json);\n\nconst requestedDate = booking.date;\nconst requestedStart = booking.time_start;\nconst requestedEnd = booking.time_end;\nconst requestedDuration = booking.duration_minutes;\n\nfunction timeToMinutes(t) {\n  if (!t || !t.includes(':')) return 0;\n  const [h, m] = t.split(':').map(Number);\n  return h * 60 + m;\n}\n\nconst reqStartMin = timeToMinutes(requestedStart);\nconst reqEndMin = timeToMinutes(requestedEnd);\n\n// Filter appointments on the same date that are active\nconst sameDayAppts = existingAppointments.filter(apt => {\n  return apt.date === requestedDate && \n         apt.status !== 'cancelled' && \n         apt.status !== 'no-show';\n});\n\n// Check for time overlaps using duration-aware logic\nlet conflicting = [];\nfor (const apt of sameDayAppts) {\n  const aptStart = timeToMinutes(apt.time_start || apt.time);\n  const aptDuration = parseInt(apt.duration_minutes) || 30;\n  const aptEnd = aptStart + aptDuration;\n  \n  if (reqStartMin < aptEnd && reqEndMin > aptStart) {\n    conflicting.push(apt);\n  }\n}\n\nconst isAvailable = conflicting.length === 0;\n\n// Generate alternative slots if not available\nlet alternatives = [];\nif (!isAvailable) {\n  const allSlots = ['09:00','09:30','10:00','10:30','11:00','11:30','12:00','12:30','13:00','13:30','14:00','14:30','15:00','15:30','16:00','16:30','17:00'];\n  \n  for (const slot of allSlots) {\n    const slotStart = timeToMinutes(slot);\n    const slotEnd = slotStart + requestedDuration;\n    \n    if (slotEnd > 18 * 60) continue;\n    \n    let slotFree = true;\n    for (const apt of sameDayAppts) {\n      const aptStart = timeToMinutes(apt.time_start || apt.time);\n      const aptDuration = parseInt(apt.duration_minutes) || 30;\n      const aptEnd = aptStart + aptDuration;\n      \n      if (slotStart < aptEnd && slotEnd > aptStart) {\n        slotFree = false;\n        break;\n      }\n    }\n    \n    if (slotFree && slot !== requestedStart) {\n      alternatives.push(slot);\n    }\n    \n    if (alternatives.length >= 3) break;\n  }\n}\n\nreturn [{\n  json: {\n    ...booking,\n    available: isAvailable,\n    conflicting_count: conflicting.length,\n    alternatives: alternatives,\n    alternatives_text: alternatives.join(', ')\n  }\n}];"
      },
