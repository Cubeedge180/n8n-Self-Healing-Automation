    {
      "parameters": {
        "jsCode": "// Process form submission and generate appointment data\nconst data = $input.first().json;\n\n// Generate unique appointment ID\nconst appointmentId = 'APT-' + Date.now().toString(36).toUpperCase();\n\n// Extract procedure name and duration from dropdown value\nconst procedureRaw = data.procedure || 'Consultatie generala (30 min)';\nconst procedureMatch = procedureRaw.match(/^(.+?)\\s*\\((\\d+)\\s*min\\)$/);\nconst procedureName = procedureMatch ? procedureMatch[1].trim() : procedureRaw;\nconst durationMinutes = procedureMatch ? parseInt(procedureMatch[2]) : 30;\n\n// Calculate end time based on procedure duration\nconst startTime = data.preferred_time || '09:00';\nconst [startH, startM] = startTime.split(':').map(Number);\nconst endTotalMinutes = startH * 60 + startM + durationMinutes;\nconst endH = Math.floor(endTotalMinutes / 60);\nconst endM = endTotalMinutes % 60;\nconst endTime = `${String(endH).padStart(2, '0')}:${String(endM).padStart(2, '0')}`;\n\n// Normalize date\nconst preferredDate = data.preferred_date || '';\n\n// Determine language\nconst language = data.language || 'ro';\n\nreturn [{\n  json: {\n    appointment_id: appointmentId,\n    lead_id: data.lead_id || '',\n    source: data.source || 'direct_form',\n    name: data.name || '',\n    email: (data.email || '').toLowerCase().trim(),\n    phone: String(data.phone || '').replace(/[^0-9+]/g, ''),\n    procedure: procedureName,\n    procedure_full: procedureRaw,\n    duration_minutes: durationMinutes,\n    date: preferredDate,\n    time_start: startTime,\n    time_end: endTime,\n    notes: data.notes || '',\n    language: language,\n    status: 'pending_confirmation',\n    created_at: new Date().toISOString()\n  }\n}];"
      },
      "id": "process-booking",
      "name": "Process Booking Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
