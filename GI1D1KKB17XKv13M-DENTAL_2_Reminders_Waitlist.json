    {
      "parameters": {
        "jsCode": "// Calculate minutes to wait until 2h before appointment\nconst input = $input.first().json;\n\nconst appointmentTime = input.appointment_time;\nif (!appointmentTime) {\n  return [{ json: { ...input, wait_minutes: 1, skip_reminder: true } }];\n}\n\nconst aptTime = DateTime.fromISO(appointmentTime).setZone('Europe/Bucharest');\nconst reminderTime = aptTime.minus({ hours: 2 });\nconst now = DateTime.now().setZone('Europe/Bucharest');\n\nlet waitMinutes = reminderTime.diff(now, 'minutes').minutes;\n\n// If reminder time already passed, skip the reminder\nif (waitMinutes < 1) {\n  return [{ json: { ...input, wait_minutes: 1, skip_reminder: true } }];\n}\n\nreturn [{\n  json: {\n    ...input,\n    wait_minutes: Math.round(waitMinutes),\n    reminder_scheduled_for: reminderTime.toISO(),\n    skip_reminder: false\n  }\n}];"
      },
      "id": "calc-wait-time",
      "name": "Calculate Wait Time",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1088,
        112
      ]
    },
