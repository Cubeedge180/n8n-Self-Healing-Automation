    {
      "parameters": {
        "jsCode": "// Normalize appointment data from webhook\nconst item = $input.first().json;\nconst body = item.body || item;\n\n// Generate UUID\nconst uuid = 'apt_' + Date.now().toString(36) + '_' + Math.random().toString(36).substr(2, 6);\n\n// Normalize phone\nlet phone = (body.patient_phone || body.phone || '').toString();\nconst hasPlus = phone.startsWith('+');\nphone = phone.replace(/\\D/g, '');\nif (hasPlus && !phone.startsWith('+')) phone = '+' + phone;\n\n// Normalize email\nconst email = (body.patient_email || body.email || '').toString().toLowerCase().trim();\n\nreturn [{\n  json: {\n    appointment_id: uuid,\n    patient_name: body.patient_name || body.name || '',\n    patient_email: email,\n    patient_phone: phone,\n    appointment_time: body.appointment_datetime || body.appointment_time || '',\n    procedure: body.service || body.procedure || '',\n    status: 'booked_pending',\n    created_at: new Date().toISOString(),\n    language: 'ro'\n  }\n}];"
      },
      "id": "prep-appointment",
      "name": "Prepare Appointment Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        464,
        112
      ]
    },
